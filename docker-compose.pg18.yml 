version: "3.9"

services:
  db:
    image: postgres:18.0
    container_name: bnpl-postgres
    environment:
      POSTGRES_DB: bnpl
      POSTGRES_USER: bnpl_user
      POSTGRES_PASSWORD: bnpl_password
    ports:
      - "5432:5432"
    volumes:
      - postgres-data:/var/lib/postgresql/data
      - ./docker/postgres/init:/docker-entrypoint-initdb.d
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U bnpl_user -d bnpl"]
      interval: 5s
      timeout: 5s
      retries: 5

volumes:
  postgres-data:
